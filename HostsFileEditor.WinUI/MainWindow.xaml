<Window
    x:Class="HostsFileEditor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:HostsFileEditor"
    mc:Ignorable="d"
    Title="Hosts File Editor">
    <Grid RowDefinitions="Auto,Auto,*" Background="Transparent" MinWidth="720" MinHeight="480">
        <Grid.Resources>
            <!-- Style to keep back button background always transparent, even when disabled -->
            <Style x:Key="PlainBackButtonStyle" TargetType="Button">
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="MinHeight" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid Background="Transparent" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- Rounded selection style for EntriesList items -->
            <Style x:Key="RoundedListViewItemStyle" TargetType="ListViewItem">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Grid x:Name="Root" Background="Transparent">
                                <Border x:Name="SelectionBackground" CornerRadius="6" Opacity="0" Background="{ThemeResource ListViewItemBackgroundSelected}"/>
                                <Border x:Name="PointerOverBackground" CornerRadius="6" Opacity="0" Background="{ThemeResource ListViewItemBackgroundPointerOver}"/>
                                <ContentPresenter x:Name="ContentPresenter"
                                                  Margin="0"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal">
                                            <Storyboard>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PointerOverBackground" Storyboard.TargetProperty="(UIElement.Opacity)">
                                                    <DiscreteDoubleKeyFrame KeyTime="0" Value="0" />
                                                </DoubleAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PointerOverBackground" Storyboard.TargetProperty="(UIElement.Opacity)">
                                                    <DiscreteDoubleKeyFrame KeyTime="0" Value="1" />
                                                </DoubleAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed"/>
                                        <VisualState x:Name="Disabled">
                                            <Storyboard>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PointerOverBackground" Storyboard.TargetProperty="(UIElement.Opacity)">
                                                    <DiscreteDoubleKeyFrame KeyTime="0" Value="0" />
                                                </DoubleAnimationUsingKeyFrames>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SelectionBackground" Storyboard.TargetProperty="(UIElement.Opacity)">
                                                    <DiscreteDoubleKeyFrame KeyTime="0" Value="0" />
                                                </DoubleAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                    <VisualStateGroup x:Name="SelectionStates">
                                        <VisualState x:Name="Unselected">
                                            <Storyboard>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SelectionBackground" Storyboard.TargetProperty="(UIElement.Opacity)">
                                                    <DiscreteDoubleKeyFrame KeyTime="0" Value="0" />
                                                </DoubleAnimationUsingKeyFrames>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PointerOverBackground" Storyboard.TargetProperty="(UIElement.Opacity)">
                                                    <DiscreteDoubleKeyFrame KeyTime="0" Value="0" />
                                                </DoubleAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Selected">
                                            <Storyboard>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SelectionBackground" Storyboard.TargetProperty="(UIElement.Opacity)">
                                                    <DiscreteDoubleKeyFrame KeyTime="0" Value="1" />
                                                </DoubleAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="PointerOverSelected">
                                            <Storyboard>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SelectionBackground" Storyboard.TargetProperty="(UIElement.Opacity)">
                                                    <DiscreteDoubleKeyFrame KeyTime="0" Value="1" />
                                                </DoubleAnimationUsingKeyFrames>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PointerOverBackground" Storyboard.TargetProperty="(UIElement.Opacity)">
                                                    <DiscreteDoubleKeyFrame KeyTime="0" Value="1" />
                                                </DoubleAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="SelectedUnfocused">
                                            <Storyboard>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SelectionBackground" Storyboard.TargetProperty="(UIElement.Opacity)">
                                                    <DiscreteDoubleKeyFrame KeyTime="0" Value="1" />
                                                </DoubleAnimationUsingKeyFrames>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PointerOverBackground" Storyboard.TargetProperty="(UIElement.Opacity)">
                                                    <DiscreteDoubleKeyFrame KeyTime="0" Value="0" />
                                                </DoubleAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <!-- Keyboard accelerators for Copy/Cut/Paste and Undo/Redo -->
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="C" Modifiers="Control" Invoked="OnCopyAcceleratorInvoked"/>
            <KeyboardAccelerator Key="X" Modifiers="Control" Invoked="OnCutAcceleratorInvoked"/>
            <KeyboardAccelerator Key="V" Modifiers="Control" Invoked="OnPasteAcceleratorInvoked"/>
            <KeyboardAccelerator Key="Z" Modifiers="Control" Invoked="OnUndoAcceleratorInvoked"/>
            <KeyboardAccelerator Key="Y" Modifiers="Control" Invoked="OnRedoAcceleratorInvoked"/>
        </Grid.KeyboardAccelerators>

        <!-- Custom title bar area to resemble Windows 11 Settings -->
        <Grid x:Name="AppTitleBar" Height="48" Padding="12,0" VerticalAlignment="Top" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <!-- Back button (disabled by default) made smaller -->
                <Button x:Name="BackButton"
                        Width="20"
                        Height="20"
                        VerticalAlignment="Center"
                        Style="{StaticResource PlainBackButtonStyle}"
                        IsEnabled="{x:Bind IsBackEnabled, Mode=OneWay}"
                        Click="OnBackClick">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72B;" FontSize="10"/>
                </Button>
                <!-- App icon image -->
                <Image Source="Assets/Square150x150Logo.png"
                       Width="20"
                       Height="20"
                       Stretch="Uniform"
                       Margin="4,0,4,0"
                       VerticalAlignment="Center"/>
                <TextBlock Text="Hosts File Editor" FontSize="14" FontWeight="Normal" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Command/Filter row with constrained CommandBar for overflow -->
        <Grid x:Name="TopCommandRow" Grid.Row="1" Background="Transparent" Visibility="{x:Bind MainViewVisibility, Mode=OneWay}" ColumnSpacing="4" Padding="8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>  <!-- Hamburger -->
                <ColumnDefinition Width="*"/>     <!-- CommandBar (stretches) -->
                <ColumnDefinition Width="Auto"/>  <!-- Filters -->
            </Grid.ColumnDefinitions>

            <!-- Hamburger button -->
            <Button x:Name="HamburgerButton"
                    Grid.Column="0"
                    Width="40"
                    Height="40"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0">
                <Button.Flyout>
                    <MenuFlyout Placement="BottomEdgeAlignedLeft">
                        <MenuFlyoutItem Text="Import" Icon="OpenFile" Click="OnImportClick"/>
                        <MenuFlyoutItem Text="Save As" Icon="SaveLocal" Click="OnSaveAsClick"/>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem Text="Archive" Click="OnArchiveClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7C3;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <ToggleMenuFlyoutItem Text="Disable Hosts" IsChecked="{x:Bind IsDisabledHosts, Mode=OneWay}" Click="OnDisableHostsClick">
                            <ToggleMenuFlyoutItem.Icon>
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8F8;"/>
                            </ToggleMenuFlyoutItem.Icon>
                        </ToggleMenuFlyoutItem>
                        <ToggleMenuFlyoutItem Text="Ping IPs" IsChecked="{x:Bind IsPingIPs, Mode=OneWay}" Click="OnPingIPsClick">
                            <ToggleMenuFlyoutItem.Icon>
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE774;"/>
                            </ToggleMenuFlyoutItem.Icon>
                        </ToggleMenuFlyoutItem>
                        <ToggleMenuFlyoutItem Text="Remove Default Text" IsChecked="{x:Bind IsRemoveDefaultText, Mode=OneWay}" Click="OnRemoveDefaultTextClick">
                            <ToggleMenuFlyoutItem.Icon>
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE75C;"/>
                            </ToggleMenuFlyoutItem.Icon>
                        </ToggleMenuFlyoutItem>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem Text="Restore Default" Click="OnRestoreClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE81C;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Open Text Editor" Click="OnOpenInTextEditorClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70F;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE700;" FontSize="16"/>
                <ToolTipService.ToolTip>
                    <ToolTip Content="Menu"/>
                </ToolTipService.ToolTip>
            </Button>

            <!-- Constrained CommandBar (enables dynamic overflow) -->
            <CommandBar Grid.Column="1"
                        HorizontalAlignment="Left"
                        Background="Transparent"
                        DefaultLabelPosition="Right"
                        Padding="0"
                        IsDynamicOverflowEnabled="True">
                <AppBarButton Icon="Save" Label="Save" Click="OnSaveClick"/>
                <AppBarButton Icon="Refresh" Label="Refresh" Click="OnRefreshClick"/>
                <AppBarSeparator/>
                <AppBarButton Icon="Add" Label="Add" Click="OnAddToTop"/>
                <AppBarButton Icon="Delete" Label="Delete" Click="OnDeleteClick"/>

                <AppBarButton Label="Duplicate" Click="OnDuplicateClick">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8C8;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator/>
                <AppBarButton Label="Up" Click="OnMoveUpClick">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70E;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="Down" Click="OnMoveDownClick">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70D;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator/>
                <AppBarButton Label="Check" Click="OnCheckClick">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE73E;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator/>
                <AppBarToggleButton Label="View Archive" IsChecked="{x:Bind IsArchiveVisible, Mode=OneWay}" Click="OnViewArchiveClick">
                    <AppBarToggleButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE71D;"/>
                    </AppBarToggleButton.Icon>
                </AppBarToggleButton>
            </CommandBar>

            <!-- Right side: filter toggle buttons + filter textbox -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4" Margin="0,0,4,0" HorizontalAlignment="Right">
                <AppBarToggleButton Label="Filter Comments" Click="OnFilterCommentsClick" LabelPosition="Collapsed" MaxWidth="36" IsChecked="True">
                    <AppBarToggleButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE90A;"/>
                    </AppBarToggleButton.Icon>
                </AppBarToggleButton>
                <AppBarToggleButton Label="Filter Disabled" Click="OnFilterDisabledClick" LabelPosition="Collapsed" MaxWidth="36" IsChecked="True">
                    <AppBarToggleButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE739;"/>
                    </AppBarToggleButton.Icon>
                </AppBarToggleButton>
                <Grid VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="FilterTextBox"
                             Grid.Row="0"
                             Width="200"
                             PlaceholderText="Filter hosts..."
                             VerticalAlignment="Center"
                             VerticalContentAlignment="Center"
                             BorderThickness="1,1,1,0"
                             TextChanged="OnFilterTextChanged"
                             GotFocus="OnFilterBoxGotFocus"
                             LostFocus="OnFilterBoxLostFocus" />
                    <Border x:Name="FilterUnderline"
                            Grid.Row="1"
                            Height="2"
                            Background="White"
                            HorizontalAlignment="Center"
                            Width="{Binding ElementName=FilterTextBox, Path=ActualWidth}"
                            Margin="0,-6,0,0"
                            CornerRadius="0,0,2,2" />
                </Grid>
            </StackPanel>
        </Grid>

        <!-- Content area -->
        <Grid Grid.Row="2" Background="Transparent">
            <!-- Main entries view -->
            <Grid x:Name="MainHost" Margin="8" RowDefinitions="Auto,*" Background="Transparent" Visibility="{x:Bind MainViewVisibility, Mode=OneWay}">
                <ListView x:Name="EntriesList"
                          Grid.Row="1"
                          Margin="0,8,0,0"
                          SelectionMode="Extended"
                          HorizontalContentAlignment="Stretch"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.HorizontalScrollMode="Disabled"
                          Background="Transparent"
                          ItemsSource="{x:Bind Entries, Mode=OneWay}">
                    <ListView.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Copy" Click="OnCopyClick" Icon="Copy" />
                            <MenuFlyoutItem Text="Cut" Click="OnCutClick" Icon="Cut" />
                            <MenuFlyoutItem Text="Paste" Click="OnPasteClick" Icon="Paste" />
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Undo" Click="OnUndoClick" Icon="Undo" />
                            <MenuFlyoutItem Text="Redo" Click="OnRedoClick" Icon="Redo" />
                        </MenuFlyout>
                    </ListView.ContextFlyout>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8" CornerRadius="4" BorderThickness="0,0,0,1" BorderBrush="#14000000" HorizontalAlignment="Stretch" Background="Transparent">
                                <Grid VerticalAlignment="Center" HorizontalAlignment="Stretch" Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="0"/>
                                        <ColumnDefinition Width="320" MinWidth="140" MaxWidth="320"/>
                                        <ColumnDefinition Width="380" MinWidth="220" MaxWidth="520"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" MinWidth="0" Margin="8,0" IsChecked="{Binding Enabled, Mode=TwoWay}"/>
                                    <TextBox Grid.Column="1" Text="{Binding IpAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="1,0" CornerRadius="4,0,0,4" PlaceholderText="IP address..." />
                                    <TextBox Grid.Column="2" Text="{Binding HostNames, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="1,0" CornerRadius="0" PlaceholderText="Host names..." />
                                    <TextBox Grid.Column="3" Text="{Binding Comment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="1,0" CornerRadius="0,4,4,0" HorizontalAlignment="Stretch" PlaceholderText="Comments..." />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Archive full view -->
            <Grid x:Name="ArchiveHost" Visibility="{x:Bind ArchiveViewVisibility, Mode=OneWay}" Margin="8" RowDefinitions="Auto,*">
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                    <TextBlock Text="Archives" FontWeight="Normal" VerticalAlignment="Center" Margin="16,0,8,0"/>
                    <CommandBar Grid.Column="1" Background="Transparent" DefaultLabelPosition="Right" Padding="0" HorizontalAlignment="Left">
                        <AppBarButton Icon="OpenFile" Label="Load" Click="OnArchiveLoadClick"/>
                        <AppBarButton Icon="Delete" Label="Delete" Click="OnArchiveDeleteClick"/>
                    </CommandBar>
                </Grid>
                <Grid Grid.Row="1">
                    <ListView x:Name="ArchiveList" Margin="0,8,0,0" Background="Transparent" ItemsSource="{x:Bind Archives, Mode=OneWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FileName}"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock Text="No archives yet." FontStyle="Italic" Foreground="Gray"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False" Visibility="{x:Bind ArchivesEmptyVisibility, Mode=OneWay}"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
