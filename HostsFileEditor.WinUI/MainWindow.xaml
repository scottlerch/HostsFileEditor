<Window
    x:Class="HostsFileEditor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:HostsFileEditor"
    mc:Ignorable="d"
    Title="Hosts File Editor">
    <Grid RowDefinitions="Auto,Auto,*" Background="Transparent" MinWidth="720" MinHeight="480">
        <Grid.Resources>
            <!-- Style to keep back button background always transparent, even when disabled -->
            <Style x:Key="PlainBackButtonStyle" TargetType="Button">
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="MinHeight" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid Background="Transparent" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <!-- Keyboard accelerators for Copy/Cut/Paste and Undo/Redo -->
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="C" Modifiers="Control" Invoked="OnCopyAcceleratorInvoked"/>
            <KeyboardAccelerator Key="X" Modifiers="Control" Invoked="OnCutAcceleratorInvoked"/>
            <KeyboardAccelerator Key="V" Modifiers="Control" Invoked="OnPasteAcceleratorInvoked"/>
            <KeyboardAccelerator Key="Z" Modifiers="Control" Invoked="OnUndoAcceleratorInvoked"/>
            <KeyboardAccelerator Key="Y" Modifiers="Control" Invoked="OnRedoAcceleratorInvoked"/>
        </Grid.KeyboardAccelerators>

        <!-- Custom title bar area to resemble Windows 11 Settings -->
        <Grid x:Name="AppTitleBar" Height="48" Padding="12,0" VerticalAlignment="Top" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <!-- Back button (disabled by default) made smaller -->
                <Button x:Name="BackButton"
                        Width="20"
                        Height="20"
                        VerticalAlignment="Center"
                        Style="{StaticResource PlainBackButtonStyle}"
                        IsEnabled="{x:Bind IsBackEnabled, Mode=OneWay}"
                        Click="OnBackClick">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72B;" FontSize="10"/>
                </Button>
                <!-- App icon image -->
                <Image Source="Assets/Square150x150Logo.png"
                       Width="20"
                       Height="20"
                       Stretch="Uniform"
                       Margin="4,0,4,0"
                       VerticalAlignment="Center"/>
                <TextBlock Text="Hosts File Editor" FontSize="14" FontWeight="Normal" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Filter + CommandBar in one row -->
        <Grid x:Name="TopCommandRow" Grid.Row="1" Background="Transparent" Visibility="{x:Bind MainViewVisibility, Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Filter textbox with left padding and small right gap -->
            <Grid Grid.Column="0" Margin="12,0,8,0" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                </Grid.RowDefinitions>
                <TextBox x:Name="FilterTextBox"
                         Grid.Row="0"
                         Width="200"
                         PlaceholderText="Filter hosts..."
                         VerticalAlignment="Center"
                         VerticalContentAlignment="Center"
                         BorderThickness="1,1,1,0"
                         TextChanged="OnFilterTextChanged"
                         GotFocus="OnFilterBoxGotFocus"
                         LostFocus="OnFilterBoxLostFocus" />
                <Border x:Name="FilterUnderline"
                        Grid.Row="1"
                        Height="2"
                        Background="White"
                        HorizontalAlignment="Center"
                        Width="{Binding ElementName=FilterTextBox, Path=ActualWidth}"
                        Margin="0,-6,0,0"
                        CornerRadius="0,0,2,2" />
            </Grid>

            <!-- Command bar occupies remaining space -->
            <CommandBar Grid.Column="1" DefaultLabelPosition="Right" Background="Transparent" Padding="0" HorizontalAlignment="Left">
                <AppBarToggleButton Label="Filter Comments" Click="OnFilterCommentsClick" LabelPosition="Collapsed" MaxWidth="36" IsChecked="True" >
                    <AppBarToggleButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE90A;"/>
                    </AppBarToggleButton.Icon>
                </AppBarToggleButton>
                <AppBarToggleButton Label="Filter Disabled" Click="OnFilterDisabledClick" LabelPosition="Collapsed" MaxWidth="36" IsChecked="True" >
                    <AppBarToggleButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE739;"/>
                    </AppBarToggleButton.Icon>
                </AppBarToggleButton>
                <AppBarSeparator/>
                <AppBarButton Icon="OpenFile" Label="Import" Click="OnImportClick"/>
                <AppBarButton Icon="Save" Label="Save" Click="OnSaveClick"/>
                <AppBarButton Icon="SaveLocal" Label="Save As" Click="OnSaveAsClick"/>
                <AppBarSeparator/>
                <AppBarButton Icon="Add" Label="Add" Click="OnAddToTop"/>
                <AppBarButton Label="Duplicate" Click="OnDuplicateClick">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8C8;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Icon="Delete" Label="Delete" Click="OnDeleteClick"/>
                <AppBarSeparator/>
                <!-- Move Up/Down -->
                <AppBarButton Label="Up" Click="OnMoveUpClick">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70E;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="Down" Click="OnMoveDownClick">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70D;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator/>
                <!-- Enable/Disable selected (toggle) -->
                <AppBarButton Label="Check" Click="OnCheckClick">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE73E;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator/>
                <!-- Hosts toggles -->
                <AppBarToggleButton Label="Disable Hosts" IsChecked="{x:Bind IsDisabledHosts, Mode=OneWay}" Click="OnDisableHostsClick">
                    <AppBarToggleButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8F8;"/>
                    </AppBarToggleButton.Icon>
                </AppBarToggleButton>
                <AppBarToggleButton Label="Ping IPs" IsChecked="{x:Bind IsPingIPs, Mode=OneWay}" Click="OnPingIPsClick">
                    <AppBarToggleButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE774;"/>
                    </AppBarToggleButton.Icon>
                </AppBarToggleButton>
                <AppBarToggleButton Label="Remove Default Text" IsChecked="{x:Bind IsRemoveDefaultText, Mode=OneWay}" Click="OnRemoveDefaultTextClick">
                    <AppBarToggleButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE75C;"/>
                    </AppBarToggleButton.Icon>
                </AppBarToggleButton>
                <AppBarSeparator/>
                <AppBarButton Label="Restore Default" Click="OnRestoreClick">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE81C;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="Refresh" Click="OnRefreshClick" Icon="Refresh"/>
                <AppBarSeparator/>
                <!-- Archive controls -->
                <AppBarButton Label="Archive" Click="OnArchiveClick">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7C3;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarToggleButton Label="View Archive" IsChecked="{x:Bind IsArchiveVisible, Mode=OneWay}" Click="OnViewArchiveClick">
                    <AppBarToggleButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE71D;"/>
                    </AppBarToggleButton.Icon>
                </AppBarToggleButton>
                <AppBarButton Label="Load Archive" Click="OnArchiveLoadClick">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE896;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="Delete Archive" Click="OnArchiveDeleteClick" Icon="Delete"/>
                <AppBarSeparator/>
                <!-- Undo/Redo moved to context menu -->
                <AppBarButton Label="Open Text Editor" Click="OnOpenInTextEditorClick">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70F;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
            </CommandBar>
        </Grid>

        <!-- Content area -->
        <Grid Grid.Row="2" Background="Transparent">
            <!-- Main entries view -->
            <Grid x:Name="MainHost" Margin="8" RowDefinitions="Auto,*" Background="Transparent" Visibility="{x:Bind MainViewVisibility, Mode=OneWay}">
                <!-- Rows -->
                <ListView x:Name="EntriesList"
                          Grid.Row="1"
                          Margin="0,8,0,0"
                          SelectionMode="Extended"
                          HorizontalContentAlignment="Stretch"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.HorizontalScrollMode="Disabled"
                          Background="Transparent"
                          ItemsSource="{x:Bind Entries, Mode=OneWay}">
                    <!-- Context menu for entries (Copy/Cut/Paste/Undo/Redo) -->
                    <ListView.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Copy" Click="OnCopyClick" Icon="Copy" />
                            <MenuFlyoutItem Text="Cut" Click="OnCutClick" Icon="Cut" />
                            <MenuFlyoutItem Text="Paste" Click="OnPasteClick" Icon="Paste" />
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Undo" Click="OnUndoClick" Icon="Undo" />
                            <MenuFlyoutItem Text="Redo" Click="OnRedoClick" Icon="Redo" />
                        </MenuFlyout>
                    </ListView.ContextFlyout>

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8" CornerRadius="4" BorderThickness="0,0,0,1" BorderBrush="#14000000" HorizontalAlignment="Stretch" Background="Transparent">
                                <Grid VerticalAlignment="Center" HorizontalAlignment="Stretch" Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="0"/>
                                        <ColumnDefinition Width="180" MinWidth="140" MaxWidth="220"/>
                                        <ColumnDefinition Width="320" MinWidth="220" MaxWidth="520"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" MinWidth="0" Margin="8,0" IsChecked="{Binding Enabled, Mode=TwoWay}"/>
                                    <TextBox Grid.Column="1" Text="{Binding IpAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="8,0" PlaceholderText="IP address..." />
                                    <TextBox Grid.Column="2" Text="{Binding HostNames, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="8,0" PlaceholderText="Host names..." />
                                    <TextBox Grid.Column="3" Text="{Binding Comment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="8,0" HorizontalAlignment="Stretch" PlaceholderText="Comments..." />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Archive full view -->
            <Grid x:Name="ArchiveHost" Visibility="{x:Bind ArchiveViewVisibility, Mode=OneWay}">
                <ListView x:Name="ArchiveList" Margin="8" Background="Transparent" ItemsSource="{x:Bind Archives, Mode=OneWay}">
                    <ListView.Header>
                        <TextBlock Text="Archives" FontWeight="SemiBold" Margin="8,8,8,8"/>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FileName}"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Window>
