<Window
    x:Class="HostsFileEditor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:HostsFileEditor"
    mc:Ignorable="d"
    Title="Hosts File Editor">
    <!-- No MinWidth/MinHeight here: a Grid min taller/wider than the window overflow-clips its edge
         rows (it hid the bottom status bar when shortened). The minimum window size is enforced on
         the AppWindow presenter instead (see TrySetAppWindowTitleBar).
         The status row (last) is a FIXED height, not Auto: an Auto status row measured to ~0 against
         the huge virtualized list, so the star content row took the whole height (the list ran to
         the bottom) and the status text overflowed its zero-height cell onto the last rows. A fixed
         height reserves the band so the list is bounded above it — and it is bound (32 or 0) so the
         archive view, whose bar collapses via MainViewVisibility, doesn't keep a dead 32px band. -->
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{x:Bind StatusRowHeight, Mode=OneWay}"/>
        </Grid.RowDefinitions>
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="C" Modifiers="Control" Invoked="OnCopyAcceleratorInvoked"/>
            <KeyboardAccelerator Key="X" Modifiers="Control" Invoked="OnCutAcceleratorInvoked"/>
            <KeyboardAccelerator Key="V" Modifiers="Control" Invoked="OnPasteAcceleratorInvoked"/>
            <KeyboardAccelerator Key="Z" Modifiers="Control" Invoked="OnUndoAcceleratorInvoked"/>
            <KeyboardAccelerator Key="Y" Modifiers="Control" Invoked="OnRedoAcceleratorInvoked"/>
            <KeyboardAccelerator Key="S" Modifiers="Control" Invoked="OnSaveAcceleratorInvoked"/>
            <KeyboardAccelerator Key="F5" Invoked="OnRefreshAcceleratorInvoked"/>
            <!-- Row-level accelerators, matching the classic (WinForms) edition. Delete and Ctrl+D
                 are not arrow keys, so they don't collide with ListView navigation and work as
                 accelerators. The Alt+Arrow (move) and Ctrl+Alt+Arrow (insert) combos DO collide —
                 the ListView consumes the arrow key for navigation before the accelerator can fire
                 (except at the first/last row, where it can't navigate) — so those are handled in
                 EntriesList's tunneling PreviewKeyDown instead. -->
            <KeyboardAccelerator Key="Delete" Invoked="OnDeleteAcceleratorInvoked"/>
            <KeyboardAccelerator Key="D" Modifiers="Control" Invoked="OnDuplicateAcceleratorInvoked"/>
        </Grid.KeyboardAccelerators>
        <Grid x:Name="AppTitleBar" Height="42" Padding="0" VerticalAlignment="Top" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                <Button x:Name="BackButton"
                        Width="38"
                        Height="36"
                        VerticalAlignment="Center"
                        Style="{StaticResource PlainBackButtonStyle}"
                        IsEnabled="{x:Bind IsBackEnabled, Mode=OneWay}"
                        Click="OnBackClick">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72B;" FontSize="11"/>
                </Button>
                <Image Source="Assets/Square150x150Logo.png"
                       Width="20"
                       Height="20"
                       Stretch="Uniform"
                       Margin="0,0,4,0"
                       VerticalAlignment="Center"/>
                <TextBlock Text="Hosts File Editor" FontSize="11" FontWeight="Normal" VerticalAlignment="Center"/>
                <!-- Dev/test HFE_HOSTS_PATH override: shown so the redirect is never silent. -->
                <TextBlock Text="{x:Bind OverrideIndicatorText}" Visibility="{x:Bind OverrideIndicatorVisibility}"
                           FontSize="11" FontStyle="Italic" VerticalAlignment="Center" Margin="8,0,0,0"
                           Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
            </StackPanel>
        </Grid>
        <Grid x:Name="TopCommandRow" Grid.Row="1" Background="Transparent" Visibility="{x:Bind MainViewVisibility, Mode=OneWay}" ColumnSpacing="4" Padding="8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup>
                    <VisualState x:Name="WideState">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="600"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="FilterPanel.(Grid.Row)" Value="0"/>
                            <Setter Target="FilterPanel.(Grid.Column)" Value="2"/>
                            <Setter Target="FilterPanel.(Grid.ColumnSpan)" Value="1"/>
                            <Setter Target="FilterPanel.HorizontalAlignment" Value="Right"/>
                            <Setter Target="FilterTextBox.Width" Value="200"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="NarrowState">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="0"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="FilterPanel.(Grid.Row)" Value="1"/>
                            <Setter Target="FilterPanel.(Grid.Column)" Value="0"/>
                            <Setter Target="FilterPanel.(Grid.ColumnSpan)" Value="3"/>
                            <Setter Target="FilterPanel.HorizontalAlignment" Value="Stretch"/>
                            <Setter Target="FilterTextBox.Width" Value="Auto"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
            <Button x:Name="HamburgerButton"
                    Grid.Column="0"
                    Width="40"
                    Height="40"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0">
                <Button.Flyout>
                    <MenuFlyout Placement="BottomEdgeAlignedLeft">
                        <MenuFlyoutItem Text="Import" Icon="OpenFile" Click="OnImportClick"/>
                        <MenuFlyoutItem Text="Save As" Icon="SaveLocal" Click="OnSaveAsClick" />
                        <MenuFlyoutItem Text="Archive" Click="OnArchiveClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7C3;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator/>
                        <ToggleMenuFlyoutItem Text="Disable Hosts" IsChecked="{x:Bind IsDisabledHosts, Mode=OneWay}" Click="OnDisableHostsClick">
                            <ToggleMenuFlyoutItem.Icon>
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8F8;"/>
                            </ToggleMenuFlyoutItem.Icon>
                        </ToggleMenuFlyoutItem>
                        <ToggleMenuFlyoutItem Text="Ping IPs" IsChecked="{x:Bind IsPingIPs, Mode=OneWay}" Click="OnPingIPsClick">
                            <ToggleMenuFlyoutItem.Icon>
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE774;"/>
                            </ToggleMenuFlyoutItem.Icon>
                        </ToggleMenuFlyoutItem>
                        <ToggleMenuFlyoutItem Text="Remove Default Text" IsChecked="{x:Bind IsRemoveDefaultText, Mode=OneWay}" Click="OnRemoveDefaultTextClick">
                            <ToggleMenuFlyoutItem.Icon>
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE75C;"/>
                            </ToggleMenuFlyoutItem.Icon>
                        </ToggleMenuFlyoutItem>
                        <MenuFlyoutItem Text="Restore Default" Click="OnRestoreClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE81C;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Open Text Editor" Click="OnOpenInTextEditorClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70F;"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE700;" FontSize="16"/>
                <ToolTipService.ToolTip>
                    <ToolTip Content="Menu"/>
                </ToolTipService.ToolTip>
            </Button>
            <CommandBar Grid.Column="1"
                        HorizontalAlignment="Left"
                        Background="Transparent"
                        DefaultLabelPosition="Right"
                        Padding="0"
                        IsDynamicOverflowEnabled="True" >
                <AppBarButton Icon="Save" Label="Save" Click="OnSaveClick" KeyboardAcceleratorTextOverride="Ctrl+S"/>
                <AppBarButton Icon="Refresh" Label="Refresh" Click="OnRefreshClick" KeyboardAcceleratorTextOverride="F5"/>
                <AppBarSeparator/>
                <AppBarButton Icon="Add" Label="Add" Click="OnAddToTop"/>
                <AppBarButton Icon="Remove" Label="Remove" Click="OnDeleteClick" x:Name="RemoveButton"/>
                <AppBarButton Label="Duplicate" Click="OnDuplicateClick" x:Name="DuplicateButton">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8C8;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator/>
                <AppBarButton Label="Up" Click="OnMoveUpClick" x:Name="MoveUpButton">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70E;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Label="Down" Click="OnMoveDownClick" x:Name="MoveDownButton">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70D;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator/>
                <AppBarButton Label="Toggle" Click="OnCheckClick" x:Name="ToggleButton">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE73E;"/>
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator/>
                <!-- Sort by (issue #81): sorts the DISPLAYED view non-destructively; "File order"
                     clears back to the file's order. Sorting disables the position-relative Move /
                     Insert commands. -->
                <AppBarButton Label="Sort" x:Name="SortButton">
                    <AppBarButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8CB;"/>
                    </AppBarButton.Icon>
                    <AppBarButton.Flyout>
                        <MenuFlyout>
                            <RadioMenuFlyoutItem Text="File order" GroupName="SortColumn" Tag="None" IsChecked="True" Click="OnSortColumnClick"/>
                            <MenuFlyoutSeparator/>
                            <RadioMenuFlyoutItem Text="IP Address" GroupName="SortColumn" Tag="IpAddress" Click="OnSortColumnClick"/>
                            <RadioMenuFlyoutItem Text="Host Names" GroupName="SortColumn" Tag="HostNames" Click="OnSortColumnClick"/>
                            <RadioMenuFlyoutItem Text="Comment" GroupName="SortColumn" Tag="Comment" Click="OnSortColumnClick"/>
                            <RadioMenuFlyoutItem Text="Enabled" GroupName="SortColumn" Tag="Enabled" Click="OnSortColumnClick"/>
                            <RadioMenuFlyoutItem Text="Status" GroupName="SortColumn" Tag="Valid" Click="OnSortColumnClick"/>
                            <MenuFlyoutSeparator/>
                            <ToggleMenuFlyoutItem Text="Descending" x:Name="SortDescendingToggle" Click="OnSortDirectionClick"/>
                        </MenuFlyout>
                    </AppBarButton.Flyout>
                </AppBarButton>
                <AppBarSeparator/>
                <AppBarToggleButton Label="View Archive" IsChecked="{x:Bind IsArchiveVisible, Mode=OneWay}" Click="OnViewArchiveClick">
                    <AppBarToggleButton.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE71D;"/>
                    </AppBarToggleButton.Icon>
                </AppBarToggleButton>
            </CommandBar>
            <!-- Compact filter panel adjusted to avoid clipping -->
            <Grid x:Name="FilterPanel" Grid.Column="2" Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="FilterTextBox"
                             Grid.Column="0"
                             Width="200"
                             PlaceholderText="Filter hosts..."
                             VerticalAlignment="Center"
                             VerticalContentAlignment="Center"
                             CornerRadius="4,0,0,4"
                             BorderThickness="1,1,0,1"
                             TextChanged="OnFilterTextChanged"
                             GotFocus="OnFilterBoxGotFocus"
                             LostFocus="OnFilterBoxLostFocus"
                             Padding="12,4,12,4"/>
                    <Button x:Name="FilterOptionsButton"
                            Grid.Column="1"
                            Width="40"
                            Height="32"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Style="{StaticResource FilterOptionsButtonStyle}"
                            ToolTipService.ToolTip="Filter options">
                        <Grid>
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE71C;" FontSize="16"/>
                            <InfoBadge x:Name="ActiveFiltersBadge"
                                       Value="{x:Bind ActiveFilterCount, Mode=OneWay}"
                                       Visibility="{x:Bind ActiveFiltersBadgeVisibility, Mode=OneWay}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Top"
                                       Margin="0,-4,-4,0" />
                        </Grid>
                        <Button.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                <ToggleMenuFlyoutItem Text="Hide Comments"
                                                      IsChecked="{x:Bind IsFilterCommentsHidden, Mode=OneWay}"
                                                      Click="OnFilterCommentsClick">
                                    <ToggleMenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE90A;"/>
                                    </ToggleMenuFlyoutItem.Icon>
                                </ToggleMenuFlyoutItem>
                                <ToggleMenuFlyoutItem Text="Hide Disabled"
                                                      IsChecked="{x:Bind IsFilterDisabledHidden, Mode=OneWay}"
                                                      Click="OnFilterDisabledClick">
                                    <ToggleMenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE739;"/>
                                    </ToggleMenuFlyoutItem.Icon>
                                </ToggleMenuFlyoutItem>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem Text="Reset Filters" Click="OnResetFiltersClick">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72C;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </Grid>
            </Grid>
        </Grid>
        <Grid Grid.Row="2" Background="Transparent">
            <Grid x:Name="MainHost" Margin="8,0,8,8" RowDefinitions="Auto,*" Background="Transparent" Visibility="{x:Bind MainViewVisibility, Mode=OneWay}">
                <!-- Logical Select-All (large lists) shows no row highlight, so surface a banner. -->
                <Border Grid.Row="0" Visibility="{x:Bind LogicalSelectAllVisibility, Mode=OneWay}"
                        Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="4" Padding="10,6">
                    <TextBlock Text="{x:Bind SelectAllBannerText, Mode=OneWay}" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                </Border>
                <ListView x:Name="EntriesList"
                          Grid.Row="1"
                          Margin="0,8,0,0"
                          IsEnabled="{x:Bind IsEntriesInteractive, Mode=OneWay}"
                          PreviewKeyDown="OnEntriesPreviewKeyDown"
                          SelectionMode="Extended"
                          HorizontalContentAlignment="Stretch"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.HorizontalScrollMode="Disabled"
                          ItemsSource="{x:Bind Entries, Mode=OneWay}"
                          SelectionChanged="OnEntriesSelectionChanged">
                    <ListView.ItemContainerTransitions>
                        <TransitionCollection>
                            <AddDeleteThemeTransition/>
                            <ReorderThemeTransition/>
                        </TransitionCollection>
                    </ListView.ItemContainerTransitions>
                    <ListView.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem x:Name="CtxCopy" Text="Copy" Click="OnCopyClick" Icon="Copy" KeyboardAcceleratorTextOverride="Ctrl+C" />
                            <MenuFlyoutItem x:Name="CtxCut" Text="Cut" Click="OnCutClick" Icon="Cut" KeyboardAcceleratorTextOverride="Ctrl+X" />
                            <MenuFlyoutItem x:Name="CtxPaste" Text="Paste" Click="OnPasteClick" Icon="Paste" KeyboardAcceleratorTextOverride="Ctrl+V" />
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem x:Name="CtxAddAbove" Text="Add Above" Click="OnInsertAboveClick" KeyboardAcceleratorTextOverride="Ctrl+Alt+Up" />
                            <MenuFlyoutItem x:Name="CtxAddBelow" Text="Add Below" Click="OnInsertBelowClick" KeyboardAcceleratorTextOverride="Ctrl+Alt+Down" />
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem x:Name="CtxUndo" Text="Undo" Click="OnUndoClick" Icon="Undo" KeyboardAcceleratorTextOverride="Ctrl+Z" />
                            <MenuFlyoutItem x:Name="CtxRedo" Text="Redo" Click="OnRedoClick" Icon="Redo" KeyboardAcceleratorTextOverride="Ctrl+Y" />
                        </MenuFlyout>
                    </ListView.ContextFlyout>
                    <!-- Style override to remove underline/border from TextBoxes within entries list -->
                    <ListView.Resources>
                        <Style TargetType="TextBox" BasedOn="{StaticResource DefaultTextBoxStyle}">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListView.Resources>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:HostsEntry">
                            <Border Padding="8,4,8,4" CornerRadius="4" BorderThickness="0,1,0,1" BorderBrush="#14000000" HorizontalAlignment="Stretch" Background="{x:Bind local:HostEntryBrushHelper.Get(Self), Mode=OneWay}">
                                <!-- Fixed IP + star Host names / Comments. Every row's Grid gets the same
                                     available width (items stretch to the viewport), so identical column
                                     definitions line up across rows automatically — no per-content
                                     measuring. The previous SharedColumnWidth attached behavior recomputed
                                     widths from the realized (virtualized) rows on every load/scroll/edit,
                                     which made the columns visibly jitter while loading a large file.
                                     200px fits every IPv4 and most compressed IPv6 literals; full-form
                                     IPv6 (up to 45 chars) still clips, so the IP cell carries a tooltip
                                     with the complete value (a TextBox hard-cuts with no ellipsis and
                                     the list has no horizontal scroll). -->
                                <Grid VerticalAlignment="Center" HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="0"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="3*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" MinWidth="0" Margin="8,0" IsChecked="{x:Bind Enabled, Mode=TwoWay}"/>
                                    <Grid Grid.Column="1" Margin="1,0">
                                        <!-- The IP cell's tooltip explains a ping failure (see IpTooltip); the failed-ping
                                             badge is IsHitTestVisible=False so it doesn't block editing, so hovering the badge
                                             falls through to this TextBox's tooltip. -->
                                        <TextBox Text="{x:Bind IpAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTipService.ToolTip="{x:Bind local:HostEntryBrushHelper.IpTooltip(IpAddress, PingFailed), Mode=OneWay}" CornerRadius="4,0,0,4" PlaceholderText="IP address..." />
                                        <!-- Per-entry ping-failed indicator (issue #9): a critical badge on the right of the
                                             IP cell, shown when the last ping to this IP didn't respond. -->
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xEA39;" FontSize="14"
                                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"
                                                  IsHitTestVisible="False"
                                                  Visibility="{x:Bind local:HostEntryBrushHelper.PingFailedVisibility(PingFailed), Mode=OneWay}"/>
                                    </Grid>
                                    <TextBox Grid.Column="2" Text="{x:Bind HostNames, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="1,0" CornerRadius="0" PlaceholderText="Host names..." />
                                    <TextBox Grid.Column="3" Text="{x:Bind Comment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="1,0" CornerRadius="0,4,4,0" HorizontalAlignment="Stretch" PlaceholderText="Comments..." />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <TextBlock Grid.Row="1" Text="No hosts entries yet." FontStyle="Italic" Foreground="Gray"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsHitTestVisible="False" Visibility="{x:Bind EntriesEmptyVisibility, Mode=OneWay}"/>
                <TextBlock Grid.Row="1" Text="No entries match the current filters." FontStyle="Italic" Foreground="Gray"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsHitTestVisible="False" Visibility="{x:Bind EntriesFilteredVisibility, Mode=OneWay}"/>
                <StackPanel Grid.Row="1" Orientation="Vertical" Spacing="12"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{x:Bind LoadingVisibility, Mode=OneWay}">
                    <ProgressRing IsActive="True" Width="40" Height="40"/>
                    <TextBlock Text="Loading hosts file…" FontStyle="Italic" Foreground="Gray" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
            <Grid x:Name="ArchiveHost" Visibility="{x:Bind ArchiveViewVisibility, Mode=OneWay}" Margin="8" RowDefinitions="Auto,*">
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                    <TextBlock Text="Archives" FontWeight="Normal" VerticalAlignment="Center" Margin="16,0,8,0"/>
                    <CommandBar Grid.Column="1" Background="Transparent" DefaultLabelPosition="Right" Padding="0" HorizontalAlignment="Left">
                        <AppBarButton x:Name="ArchiveLoadButton" Icon="OpenFile" Label="Load" Click="OnArchiveLoadClick" IsEnabled="False"/>
                        <AppBarButton x:Name="ArchiveDeleteButton" Icon="Delete" Label="Delete" Click="OnArchiveDeleteClick" IsEnabled="False"/>
                    </CommandBar>
                </Grid>
                <Grid Grid.Row="1">
                    <ListView x:Name="ArchiveList" Margin="0,8,0,0" Background="Transparent" ItemsSource="{x:Bind Archives, Mode=OneWay}" SelectionChanged="OnArchiveSelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:HostsArchive">
                                <TextBlock Text="{x:Bind FileName}"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock Text="No archives yet." FontStyle="Italic" Foreground="Gray"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False" Visibility="{x:Bind ArchivesEmptyVisibility, Mode=OneWay}"/>
                </Grid>
            </Grid>
        </Grid>
        <!-- Status bar: total lines + host (enabled) entries, mirroring the classic edition's
             StatusStrip. Background is Transparent and borderless, so it blends seamlessly into the
             window's Mica backdrop; it sits in its own fixed-height grid row, so no list content is
             ever laid out behind it.

             The backplate underneath exists because of a WinUI composition bug with enormous
             virtualized lists: past roughly 2^20 device-independent pixels of panel extent
             (~32K rows here), the renderer stops clipping the list's bottom-edge rows — the last
             partially-visible row paints in FULL, plus the next cache row — straight through the
             ListView's viewport clip, an explicit ancestor UIElement.Clip,
             CanContentRenderOutsideBounds=False, and CacheLength=0 (all verified ineffective;
             element bounds via UIA stay correct, so it is a raster-level escape, not layout). The
             stray pixels land under this transparent band and show through it. They only ever paint
             DOWNWARD past the list (title/command bars stay clean), and opaque content drawn later
             in the tree occludes them — so when the list is large enough for the bug to trigger,
             an opaque backplate in SolidBackgroundFillColorBase (the exact base color Mica tints,
             i.e. "Mica minus the desktop tint") slides in behind the text. Normal-sized files
             (≤10K rows, empirically clean with margin: breakage sets in between 10K and 50K) keep
             the true-Mica look. -->
        <Grid Grid.Row="3" Visibility="{x:Bind MainViewVisibility, Mode=OneWay}">
            <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    Visibility="{x:Bind StatusBackplateVisibility, Mode=OneWay}"/>
            <Border Background="Transparent" Padding="14,5">
                <Grid>
                    <TextBlock Text="{x:Bind StatusText, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <!-- Ping-in-progress indicator (issue #9): an indeterminate ring shown on the
                         right while any ping is in flight. -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Spacing="8"
                                Visibility="{x:Bind PingProgressVisibility, Mode=OneWay}">
                        <ProgressRing IsActive="True" Width="16" Height="16"/>
                        <TextBlock Text="Pinging…"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
